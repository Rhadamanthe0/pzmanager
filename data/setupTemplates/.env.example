#!/bin/bash
# ------------------------------------------------------------------------------
# .env.example - Centralized configuration template for all scripts
# ------------------------------------------------------------------------------
# Usage: This file will be automatically copied to .env on first script run
#
# This file contains all environment variables shared by the Project Zomboid
# server management scripts.
# ------------------------------------------------------------------------------

# === Users and base paths ===
export PZ_USER="pzuser"
export PZ_HOME="/home/${PZ_USER}"
export PZ_MANAGER_DIR="${PZ_HOME}/pzmanager"
export PZ_SCRIPTS_DIR="${PZ_MANAGER_DIR}/scripts"
export PZ_DATA_DIR="${PZ_MANAGER_DIR}/data"

# === Project Zomboid server ===
export PZ_INSTALL_DIR="${PZ_DATA_DIR}/pzserver"
export PZ_CONTROL_PIPE="${PZ_INSTALL_DIR}/zomboid.control"
export PZ_SERVICE_NAME="zomboid.service"
export PZ_SOURCE_DIR="${PZ_MANAGER_DIR}/Zomboid"

# Nom du monde. PZ en dérive TOUS les fichiers de la partie : db/<nom>.db,
# Server/<nom>.ini, Server/<nom>_SandboxVars.lua, _spawnpoints, _spawnregions.
# "servertest" est le défaut du jeu ; zomboid.service le passe explicitement via
# -servername pour que le nom du monde et les chemins lus par les scripts ne
# puissent pas diverger.
#
# ATTENTION : le changer sur un serveur existant = NOUVEAU MONDE VIERGE. PZ crée
# la partie <nouveau nom> à côté ; l'ancienne reste sur le disque sous son nom,
# intacte mais ignorée (whitelist et personnages compris). Pour renommer un monde
# existant, renommer d'abord les fichiers, serveur arrêté.
export PZ_SERVER_NAME="servertest"

# Chemins dérivés du monde. Définis ici une seule fois : les scripts les lisent
# au lieu de recomposer "servertest" chacun de leur côté.
export PZ_DB_PATH="${PZ_SOURCE_DIR}/db/${PZ_SERVER_NAME}.db"
export PZ_INI_PATH="${PZ_SOURCE_DIR}/Server/${PZ_SERVER_NAME}.ini"

# === Network ports ===
# Ports du serveur PZ (à changer si plusieurs serveurs sur la même machine)
export PZ_PORT_GAME=16261
export PZ_PORT_GAME2=16262
export PZ_PORT_RCON=8766
export PZ_PORT_STEAM=27015

# === SteamCMD ===
export STEAMCMD_PATH="/usr/games/steamcmd"
export STEAM_APP_ID="380870"
export STEAM_BETA_BRANCH="unstable"
# Compte Steam pour les téléchargements steamcmd (app_update serveur + mods Workshop).
# Laisser VIDE => "anonymous". Depuis 2026 Steam a retiré Project Zomboid des
# téléchargements Workshop anonymes : un mod NEUF ou MIS À JOUR ne se télécharge
# plus en anonyme et fait crasher le serveur au boot. Renseigner ici un compte
# Steam DÉDIÉ possédant PZ (jamais un compte personnel : steamcmd stocke sur le
# disque un jeton de login + statut "machine de confiance" réutilisable). Se
# connecter une fois manuellement (`steamcmd +login <compte>`) pour mettre le
# jeton en cache (Steam Guard validé une seule fois), puis renseigner le nom ici.
export STEAM_LOGIN=""

# === Java JRE ===
export JAVA_VERSION="25"
export JAVA_PACKAGE="openjdk-${JAVA_VERSION}-jre-headless"
export JAVA_PATH="/usr/lib/jvm/java-${JAVA_VERSION}-openjdk-amd64"

# === Backups ===
export BACKUP_DIR="${PZ_DATA_DIR}/dataBackups"
export BACKUP_LATEST_LINK="${BACKUP_DIR}/latest"
export BACKUP_RETENTION_DAYS=14

# === External synchronization ===
export SYNC_BACKUPS_DIR="${PZ_DATA_DIR}/fullBackups"

# === Logs ===
export LOG_BASE_DIR="${PZ_SCRIPTS_DIR}/logs"
export LOG_ZOMBOID_DIR="${LOG_BASE_DIR}/zomboid"
export LOG_MAINTENANCE_DIR="${LOG_BASE_DIR}/maintenance"
export LOG_RETENTION_DAYS=30

# === Whitelist ===
# Seuil d'inactivité (jours) pour la purge auto des accès (whitelist + SteamID).
export WHITELIST_PURGE_DAYS=90

# === Maintenance ===
export REBOOT_ON_MAINTENANCE=true   # Redémarrer la machine après maintenance (false = restart service uniquement)

# === Stabilité mémoire (redémarrage adaptatif) ===
# Le serveur redémarre automatiquement quand le heap Java (occupation APRÈS GC
# majeur, lue dans logs/zomboid/gc.log) atteint ce % du -Xmx. Le heap se remplit
# de cellules de map vivantes que rien ne libère (OOM Java vers ~15 h d'uptime) :
# un restart est le seul reclaim. Vérifié ~toutes les 3 min par pz-heapcheck.timer.
# Remplace l'ancien redémarrage fixe 11h/17h/23h ; la maintenance de 04:30 reste
# le filet de sécurité quotidien.
export HEAP_RESTART_PERCENT=95        # seuil d'occupation heap (%) déclenchant le restart
export HEAP_RESTART_DELAY="5m"        # préavis joueurs avant restart (30m|15m|5m|2m|30s|now)

# Override du heap max Java (Xmx), en Go. Vide = moitié de la RAM physique
# (défaut sûr). ATTENTION: au-dessus de la moitié de la RAM c'est RISQUÉ — avec
# AlwaysPreTouch tout le Xmx est résident dès le boot, et Xmx + ~5 Go de natif PZ
# peut dépasser la RAM totale → OOM-killer OS (crash brutal). configureJvm.sh
# relit cette valeur à chaque maintenance. Redémarrage requis pour l'appliquer.
#export PZ_XMX_GB=8

# === Discord (Optional) ===
# To enable Discord notifications, create a webhook in your Discord server:
# Server Settings → Integrations → Webhooks → New Webhook
# Then paste the webhook URL below (remove the # to uncomment)
export DISCORD_WEBHOOK=""

# === Discord Bot (Optional) ===
# Bot qui exécute les commandes pzm depuis Discord (slash command /pzm).
# 1. Créer une application + bot sur https://discord.com/developers/applications
#    (onglet Bot → Reset Token pour obtenir le token).
# 2. Inviter le bot avec les scopes OAuth2 "bot" + "applications.commands".
# 3. Activer le mode développeur Discord (Paramètres → Avancés) puis clic droit
#    pour "Copier l'identifiant" du serveur / salon / rôle.
# Installer/activer ensuite : pzm install discord
export DISCORD_BOT_TOKEN=""            # Token du bot (secret)
export DISCORD_BOT_GUILD_ID=""         # ID du serveur Discord (sync instantané des commandes)
export DISCORD_BOT_CHANNEL_ID=""       # ID du/des salon(s) autorisé(s) (séparés par des virgules)
export DISCORD_BOT_ADMIN_ROLE_ID=""    # ID(s) du/des rôle(s) autorisé(s) (séparés par virgule)
export DISCORD_BOT_CMD_TIMEOUT=2400    # Timeout d'exécution d'une commande (secondes)
# Salon où le bot notifie CHAQUE mort de joueur (pseudo, coordonnées, PvP/Non-PvP,
# heure ; la cause n'est pas journalisée par le serveur vanilla). Vide = désactivé.
export DISCORD_BOT_DEATH_CHANNEL_ID="" # ID du salon des notifications de mort

# Salon de MONITORING : le bot y poste, toutes les MONITORING_INTERVAL secondes,
# un embed de santé (uptime, heap Java, RSS/natif, RAM système, températures,
# CPU, disque, GC, alertes pré-crash). Un message par cycle = « boîte noire »
# pour diagnostiquer un crash a posteriori. Le bot a besoin de View Channel +
# Send Messages + Embed Links dans ce salon. Vide = désactivé.
export DISCORD_BOT_MONITORING_CHANNEL_ID="" # ID du salon de monitoring
export DISCORD_BOT_MONITORING_INTERVAL=60   # Intervalle du monitoring (secondes, min 15)
